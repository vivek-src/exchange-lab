# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=exchange_lab
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# Redis Configuration
REDIS_URL=redis://redis:6379

# Service Ports (Internal Docker Network)
PORT_WEB=3000
PORT_API=3001
PORT_WS=3002

# Next.js Public URLs
NEXT_PUBLIC_BASE_URL=http://localhost
NEXT_PUBLIC_REST_API_URL=http://localhost/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost/ws
NEXT_PUBLIC_BACKEND=/api/

# Auth & Secrets
JWT_SECRET=your_jwt_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost

# Third-Party API Keys
GITHUB_ID=your_github_id_here
GITHUB_SECRET=your_github_secret_here
MAILTRAP_TOKEN=your_mailtrap_token_here
RESEND_API_KEY=your_resend_api_key_here
